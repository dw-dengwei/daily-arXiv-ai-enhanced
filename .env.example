OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LANGUAGE=Chinese
CATEGORIES="cs.CV, cs.CL"
MODEL_NAME=gpt-4o-mini
DISABLE_SENSITIVE_CHECK=true

# Optional Arxiv API configuration
ARXIV_API_DELAY_SECONDS=10
ARXIV_API_NUM_RETRIES=5

# Optional local auth password for setup-local-auth.sh
ACCESS_PASSWORD=

# Optional token used by some GitHub-related flows
TOKEN_GITHUB=
